#!/bin/sh /etc/rc.common

USE_PROCD=1
START=80
STOP=10

PROG=/usr/bin/quickfile-go-api
CONFIG=quickfile-go

start_service() {
	[ -x "$PROG" ] || return 1

	config_load "$CONFIG"
	local enabled listen_addr listen_port enable_terminal max_upload_mb max_edit_mb auto_listen
	config_get_bool enabled main enabled 1
	[ "$enabled" = "1" ] || return 0

	config_get listen_addr main listen_addr 'auto'
	config_get listen_port main listen_port '8989'
	config_get_bool enable_terminal main enable_terminal 1
	config_get max_upload_mb main max_upload_mb '0'
	config_get max_edit_mb main max_edit_mb '0'

	# LAN-only default: resolve "auto" to network.lan.ipaddr.
	# Do not bind it before netifd has actually assigned the address during boot.
	# The LAN interface trigger below starts/restarts the service once LAN is ready.
	auto_listen=0
	if [ -z "$listen_addr" ] || [ "$listen_addr" = "auto" ]; then
		auto_listen=1
		listen_addr="$(uci -q get network.lan.ipaddr 2>/dev/null)"
		[ -n "$listen_addr" ] || listen_addr="192.168.1.1"
	fi

	if [ "$auto_listen" = "1" ] && ! ip -4 addr show 2>/dev/null | grep -q "inet ${listen_addr}/"; then
		logger -t quickfile-go "LAN address ${listen_addr} is not ready; waiting for lan interface event"
		return 0
	fi

	procd_open_instance
	procd_set_param command "$PROG" \
		-listen "${listen_addr}:${listen_port}" \
		-enable-exec="$enable_terminal" \
		-max-upload-mb "$max_upload_mb" \
		-max-edit-mb "$max_edit_mb"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	# Re-evaluate the LAN bind address after network/config changes. This also
	# recovers first-boot startup when the package starts before br-lan has its IP.
	procd_add_reload_trigger "$CONFIG" "network"
	procd_add_interface_trigger "interface.*" "lan" /etc/init.d/quickfile-go reload
}

reload_service() {
	restart
}
